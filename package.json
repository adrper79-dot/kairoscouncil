{
  "name": "kairos-council",
  "version": "0.0.1",
  "private": true,
  "description": "A living card game where real astronomical data governs card power",
  "author": "Adrian Perry <adrian@thefactory.dev>",
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "validate:arch": "bash scripts/validate-architecture.sh",
    "docs:generate": "bash scripts/generate-docs.sh",
    "docs:check": "bash scripts/check-docs-coverage.sh",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
